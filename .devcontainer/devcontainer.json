{
  "name": "C# (.NET) Project",
  "image": "mcr.microsoft.com/devcontainers/dotnet:9.0",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "qwtel.sqlite-viewer"
      ]
    }
  },
  "forwardPorts": [5242],
  "postCreateCommand": "dotnet tool install --global dotnet-ef --version 9.0.0 && dotnet restore",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.dotnet/tools"
  },
  "portsAttributes": {
    "5242": {
      "label": "Todo API Port",
      "onAutoForward": "notify",
      "visibility": "public" 
    }
  } 
}