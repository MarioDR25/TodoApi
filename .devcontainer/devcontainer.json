{
  "name": "C# (.NET) Project",
  "image": "mcr.microsoft.com/devcontainers/dotnet:8.0",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",          // El lenguaje
        "ms-dotnettools.csdevkit",        // LA QUE TE FALTA (Gestiona la compilación)
        "ms-dotnettools.vscode-dotnet-runtime", // Asegura que el runtime esté activo
        "qwtel.sqlite-viewer"             // Para ver tu base de datos
      ]
    }
  },
  "forwardPorts": [5242],
  "postCreateCommand": "dotnet tool install --global dotnet-ef --version 9.0.0 && dotnet restore",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.dotnet/tools"
  },
  "portsAttributes": {
    "5242": {
      "label": "Todo API Port",
      "onAutoForward": "notify",
      "visibility": "public" 
    }
  } 
}
